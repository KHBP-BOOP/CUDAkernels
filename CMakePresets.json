{
    "version": 8,
    "configurePresets": [
        {
            "name": "GCC-13.3.0-x86_64-linux-gnu",
            "displayName": "GCC-13.3.0-x86_64-linux-gnu",
            "description": "Using compilers: C = /usr/bin/x86_64-linux-gnu-gcc-13, CXX = /usr/bin/x86_64-linux-gnu-g++-13",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "cacheVariables": {
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/install/${presetName}",
                "CMAKE_C_COMPILER": "/usr/bin/x86_64-linux-gnu-gcc-13",
                "CMAKE_CXX_COMPILER": "/usr/bin/x86_64-linux-gnu-g++-13",
                "CMAKE_CUDA_COMPILER": "/usr/local/cuda-13.2/bin/nvcc",
                "CMAKE_BUILD_TYPE": "Debug"
            }
        }
    ]
}